{
  "name": "ai-council",
  "version": "6.9.0-beta",
  "private": true,
  "scripts": {
    "test": "npm run test:syntax && npm run test:unit && npm run test:e2e",
    "test:syntax": "node --check app.js && node --check sw.js && node --check translations.js",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:report": "npx playwright show-report",
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test:unit": "node --test tests/unit/*.test.mjs"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "vite": "latest"
  }
}
